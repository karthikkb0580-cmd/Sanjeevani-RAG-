# =============================================================================
# Sanjeevani AI - RAG Service Environment Configuration
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=Sanjeevani RAG Service
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── API Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2
OPENAI_REQUEST_TIMEOUT=60

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=research_documents
QDRANT_USE_HTTPS=false

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
CHUNK_MIN_SIZE=50

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RETRIEVAL_SIMILARITY_THRESHOLD=0.65
MMR_LAMBDA=0.5
RERANKER_TOP_N=5

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt,docx
UPLOAD_DIR=/tmp/rag_uploads

# ── Gemini (Future) ───────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
